<html>
<head>
  <title>My Closet</title>
  <HTA:APPLICATION
    ID="MyClosetSplash"
    APPLICATIONNAME="My Closet"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="no"
    WINDOWSTATE="normal"
    SCROLL="no"
  />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #faf8f5;
      color: #2d1f1f;
      width: 380px;
      height: 300px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 14px;
      user-select: none;
    }

    .icon {
      font-size: 48px;
      line-height: 1;
      animation: sway 2s ease-in-out infinite;
    }
    @keyframes sway {
      0%, 100% { transform: rotate(-4deg); }
      50%       { transform: rotate(4deg);  }
    }

    h1 {
      font-size: 22px;
      font-weight: 600;
      color: #7a2d4e;
    }

    .status {
      font-size: 13px;
      color: #9a7a80;
      text-align: center;
      min-height: 18px;
    }

    .dots span {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #c97fa0;
      margin: 0 3px;
      animation: bounce 1.2s infinite;
    }
    .dots span:nth-child(2) { animation-delay: 0.2s; }
    .dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes bounce {
      0%, 80%, 100% { transform: translateY(0);    opacity: 0.4; }
      40%           { transform: translateY(-8px); opacity: 1;   }
    }

    .bar-track {
      width: 220px;
      height: 4px;
      background: #ecdde4;
      border-radius: 2px;
      overflow: hidden;
    }
    .bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #c97fa0, #e8a0b8);
      border-radius: 2px;
      width: 0%;
      transition: width 0.4s ease;
    }

    /* Phone URL card — hidden until ready */
    .phone-card {
      display: none;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      background: #f5ecf0;
      border: 1px solid #e4cdd5;
      border-radius: 10px;
      padding: 10px 18px;
      width: 90%;
    }
    .phone-card.show { display: flex; }
    .phone-label {
      font-size: 11px;
      color: #9a7a80;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .phone-url {
      font-size: 15px;
      font-weight: 600;
      color: #7a2d4e;
      cursor: pointer;
      text-decoration: underline;
    }
    .phone-hint {
      font-size: 11px;
      color: #b09098;
      text-align: center;
    }

    .close-btn {
      background: #7a2d4e;
      color: white;
      border: none;
      border-radius: 20px;
      padding: 7px 24px;
      font-size: 13px;
      cursor: pointer;
      display: none;
    }
    .close-btn.show { display: block; }
    .close-btn:hover { background: #5e2039; }
  </style>
</head>
<body>
  <div class="icon">👗</div>
  <h1>My Closet</h1>
  <div class="status" id="status">Checking for updates…</div>

  <div class="dots" id="dots">
    <span></span><span></span><span></span>
  </div>

  <div class="bar-track" id="barTrack">
    <div class="bar-fill" id="bar"></div>
  </div>

  <!-- Shown after ready -->
  <div class="phone-card" id="phoneCard">
    <div class="phone-label">📱 Open on your iPhone or iPad</div>
    <div class="phone-url" id="phoneUrl" onclick="OpenPhoneUrl()">loading…</div>
    <div class="phone-hint">Open Safari on your phone and type that address,<br>then tap Share → Add to Home Screen</div>
  </div>

  <button class="close-btn" id="closeBtn" onclick="window.close()">Close this window</button>

  <script language="VBScript">
    Dim fso, readyFlag, pct, isReady

    Set fso   = CreateObject("Scripting.FileSystemObject")
    readyFlag = Environ("TEMP") & "\mycloset_ready.flag"
    isReady   = False
    pct       = 10

    ' Clean up stale flag
    If fso.FileExists(readyFlag) Then fso.DeleteFile readyFlag

    Sub OpenPhoneUrl()
      Dim shell
      Set shell = CreateObject("WScript.Shell")
      shell.Run "cmd /c start " & document.getElementById("phoneUrl").innerHTML
    End Sub

    Sub Tick()
      If isReady Then Exit Sub

      ' Animate bar
      If pct < 85 Then pct = pct + 4
      document.getElementById("bar").style.width = pct & "%"

      If pct < 30 Then
        document.getElementById("status").innerHTML = "Checking for updates&hellip;"
      ElseIf pct < 55 Then
        document.getElementById("status").innerHTML = "Starting your closet&hellip;"
      Else
        document.getElementById("status").innerHTML = "Almost ready&hellip;"
      End If

      ' Check ready flag
      If fso.FileExists(readyFlag) Then
        fso.DeleteFile readyFlag
        isReady = True

        ' Fill bar
        document.getElementById("bar").style.width = "100%"
        document.getElementById("status").innerHTML = "Your closet is open!"

        ' Hide dots and bar
        document.getElementById("dots").style.display    = "none"
        document.getElementById("barTrack").style.display = "none"

        ' Read local IP from temp file
        Dim ipFile, ipPath, localIP
        ipPath = Environ("TEMP") & "\mycloset_ip.txt"
        localIP = "your-computer-ip"
        If fso.FileExists(ipPath) Then
          Set ipFile = fso.OpenTextFile(ipPath, 1)
          localIP = Trim(ipFile.ReadLine())
          ipFile.Close
        End If

        ' Show phone card
        document.getElementById("phoneUrl").innerHTML = "http://" & localIP & ":3737"
        document.getElementById("phoneCard").className = "phone-card show"
        document.getElementById("closeBtn").className  = "close-btn show"

        ' Resize window to fit new content
        window.resizeTo 380, 340
      End If
    End Sub

    window.setInterval "Tick()", 600
    window.setTimeout  "window.close()", 120000
  </script>
</body>
</html>
