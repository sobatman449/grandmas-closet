<html>
<head>
  <title>My Closet</title>
  <HTA:APPLICATION
    ID="MyCLosetSplash"
    APPLICATIONNAME="My Closet"
    BORDER="thin"
    BORDERSTYLE="normal"
    CAPTION="yes"
    SHOWINTASKBAR="yes"
    SINGLEINSTANCE="yes"
    SYSMENU="no"
    WINDOWSTATE="normal"
    SCROLL="no"
  />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #faf8f5;
      color: #2d1f1f;
      width: 360px;
      height: 260px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 18px;
      user-select: none;
    }

    .icon {
      font-size: 52px;
      line-height: 1;
      animation: sway 2s ease-in-out infinite;
    }

    @keyframes sway {
      0%, 100% { transform: rotate(-4deg); }
      50%       { transform: rotate(4deg);  }
    }

    h1 {
      font-size: 22px;
      font-weight: 600;
      color: #7a2d4e;
      letter-spacing: 0.01em;
    }

    .status {
      font-size: 13px;
      color: #9a7a80;
      min-height: 18px;
      text-align: center;
      transition: opacity 0.3s;
    }

    .dots span {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #c97fa0;
      margin: 0 3px;
      animation: bounce 1.2s infinite;
    }
    .dots span:nth-child(2) { animation-delay: 0.2s; }
    .dots span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes bounce {
      0%, 80%, 100% { transform: translateY(0);    opacity: 0.4; }
      40%           { transform: translateY(-8px); opacity: 1;   }
    }

    .bar-track {
      width: 220px;
      height: 4px;
      background: #ecdde4;
      border-radius: 2px;
      overflow: hidden;
    }
    .bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #c97fa0, #e8a0b8);
      border-radius: 2px;
      width: 0%;
      transition: width 0.4s ease;
    }
  </style>
</head>
<body>
  <div class="icon">👗</div>
  <h1>My Closet</h1>
  <div class="status" id="status">Checking for updates…</div>
  <div class="dots">
    <span></span><span></span><span></span>
  </div>
  <div class="bar-track">
    <div class="bar-fill" id="bar"></div>
  </div>

  <script language="VBScript">
    Dim fso, readyFlag, updateFlag, bar, status, pct

    Set fso = CreateObject("Scripting.FileSystemObject")
    readyFlag = Environ("TEMP") & "\mycloset_ready.flag"

    ' Clean up old flag immediately
    If fso.FileExists(readyFlag) Then fso.DeleteFile readyFlag

    pct = 10

    Sub Tick()
      Dim appDir
      appDir = fso.GetParentFolderName(Document.Location.PathName)
      updateFlag = appDir & "\.updated"

      ' Animate progress bar
      If pct < 85 Then
        pct = pct + 5
      End If

      document.getElementById("bar").style.width = pct & "%"

      ' Update status message
      If pct < 30 Then
        document.getElementById("status").innerHTML = "Checking for updates&hellip;"
      ElseIf pct < 60 Then
        document.getElementById("status").innerHTML = "Starting your closet&hellip;"
      Else
        document.getElementById("status").innerHTML = "Almost ready&hellip;"
      End If

      ' Check if server is ready
      If fso.FileExists(readyFlag) Then
        fso.DeleteFile readyFlag
        document.getElementById("bar").style.width = "100%"
        document.getElementById("status").innerHTML = "Opening in your browser!"
        window.setTimeout "CloseSplash()", 800
      End If
    End Sub

    Sub CloseSplash()
      window.close()
    End Sub

    ' Poll every 600ms
    window.setInterval "Tick()", 600

    ' Safety close after 90 seconds
    window.setTimeout "window.close()", 90000
  </script>
</body>
</html>
